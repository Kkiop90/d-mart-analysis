.ewa-ptp-header-maker-rtl { background-color: rgb(237, 235, 233); height: 26px; padding: 10px 16px 16px 10px; }

.ewa-ptp-title-inner { height: 30px; overflow: hidden; text-overflow: ellipsis; }

.ewa-ptp-title-maker { display: inline-block; font-family: "Segoe UI Semibold", "Segoe UI Web", Arial, Verdana, sans-serif; height: 22px; overflow: hidden; }

.ewa-ptp-title-maker-react { display: inline-block; font-family: "Segoe UI"; font-style: normal; letter-spacing: 0px; line-height: 20px; overflow: hidden; }

.ewa-ptp-title-ideas, .ewa-ptp-title-navigation { display: inline-block; font-family: "Segoe UI"; font-style: normal; line-height: 22px; max-width: 80%; }


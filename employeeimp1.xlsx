.skel-app-header-panel-placeHolder { background-color: rgb(16, 124, 65); display: block; height: 48px; position: absolute; top: 0px; width: 100%; }

.skel-zindex .skel-app-header-panel-placeHolder { z-index: 1009; }

.skel-root:not(.skel-ribbon) .skel-app-header-panel-placeHolder { background-color: rgb(0, 0, 0); }

.skel-app-header-panel-app-brand { color: rgb(255, 255, 255); display: inline-block; font-family: SegoeUI-SemiBold-final, "Segoe UI Semibold", SegoeUI-Regular-final, "Segoe UI", "Segoe UI Web (West European)", Segoe, -apple-system, BlinkMacSystemFont, Roboto, "Helvetica Neue", "Tahoma, Helvetica", Arial, "sans-serif"; font-size: 16px; position: absolute; }

.skel-ltr .skel-app-header-panel-app-brand { left: 48px; }


.ewa-ptp-ltr .ewa-ptp-applybutton { margin-right: 10px; }

.ewa-ptp-rtl .ewa-ptp-applybutton { margin-left: 10px; }

.ewa-ptp-applybutton-disabled, .ewa-ptp-buttons button[disabled="disabled"], .ewa-ptp-buttons input[disabled="disabled"] { color: graytext; }

.ewa-ptp-button { background-color: initial; border: 1px solid rgb(162, 166, 171); margin: 10px 0px 0px; min-width: 95px; overflow: visible; padding-bottom: 3px; padding-top: 5px; text-align: center; text-transform: uppercase; }


  .ewa-android .msospAFrameContainer { min-height: 500px; }
}

.ewr-presentMode-on.grid-visual-refresh.msospAFrameContainer { top: 0px !important; }

.ewr-presentMode-on.grid-visual-refresh .ewa-contentarea { background-color: rgb(50, 49, 48); }


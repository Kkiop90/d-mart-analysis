.ewa-modernrowresizer { border-width: 0px 0px 2px; height: 0px; margin-top: -2px; }

.ewa-highlight-resizedcolumn, .ewa-highlight-resizedrow { position: absolute; border-style: solid; border-color: rgb(16, 124, 65); background-color: transparent; z-index: 98; touch-action: none; }

.ewr-grdcontarea-ltr .ewa-highlight-resizedcolumn { cursor: ew-resize; border-width: 0px 2px; width: 0px; margin-left: -2px; }

.ewr-grdcontarea-rtl .ewa-highlight-resizedcolumn { cursor: ew-resize; border-width: 0px 2px; width: 0px; margin-right: -2px; }

.ewa-highlight-resizedrow { cursor: ns-resize; border-width: 2px 0px; height: 0px; margin-top: -2px; }

.ewa-headerresize-dragtooltip { position: absolute; background-color: rgb(255, 255, 255); z-index: 1003; border: 1px solid rgb(110, 123, 138); height: 18px; font-size: 12px; padding-left: 2px; padding-right: 2px; white-space: nowrap; }

.ewa-touch-resizer { position: absolute; overflow: hidden; height: 16px; width: 16px; padding: 2px 7px; z-index: 98; touch-action: none; }

.ewa-grid-ltr .ewr-rowhdrcontainer .ewa-touch-resizer { right: 0px; }


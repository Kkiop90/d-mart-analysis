.ewr-presentMode-on.ewr-namedsheetview div[id^="tabbedTaskPaneContainer"] { border-left: 1px solid rgb(0, 0, 0) !important; }

.ewa-root-ltr .ewr-presentMode-transition, .ewr-presentMode-transition div[id^="tabbedTaskPaneContainer"], .ewr-presentMode-transition.grid-visual-refresh .ewa-contentarea { transition: background-color 0.4s linear, background 0.4s linear; }

.leg-gallerybutton { height: 48px; position: absolute; width: auto; }


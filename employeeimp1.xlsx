.ewa-ptp-rtl .ewa-ptp-description, .ewa-ptp-rtl .ewa-ptp-title-inner { text-align: right; }

.ewa-ptp-description { cursor: default; margin: 8px 8px 16px; }

.ewa-ptp-parameters { inset: 85px 8px 45px; display: block; overflow: auto; position: absolute; }

.ewa-ptp-paramname { cursor: default; font-weight: 700; max-width: 75px; overflow: hidden; padding-top: 4px; text-overflow: ellipsis; white-space: nowrap; }

.ewa-ptp-ltr .ewa-ptp-paramname { float: left; margin: 0px 8px 0px 0px; }

.ewa-ptp-rtl .ewa-ptp-paramname { float: right; margin: 0px 0px 0px 8px; }


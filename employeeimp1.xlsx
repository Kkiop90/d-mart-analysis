.ql-und { text-decoration: underline; }

.ql-dbl { text-decoration-style: double; }

.ql-editor ::selection { background: rgb(198, 198, 198); }

.ql-editor .selection-contrast::selection, .ql-editor .selection-contrast ::selection { color: white; }

.preview-span::after { color: rgba(0, 0, 0, 0.35); content: attr(data-placeholder); left: 0px; pointer-events: none; position: relative; }

.ql-rich-value-active-pill, .ql-rich-value-inactive-pill { white-space: nowrap; box-sizing: border-box; position: relative; left: 0.1px; line-height: 1.1; border-radius: 4px; }

.ql-rich-value-active-pill { background-color: rgb(16, 124, 65); }

.ql-rich-value-inactive-pill { background-color: rgb(118, 118, 118); }

.ql-rich-value-active-pill::before, .ql-rich-value-inactive-pill::before { content: attr(data-rich-value-icon); font-family: XLYellow; font-weight: normal; display: inline-block; margin: 2px 1px 2px 2px; user-select: none; color: white; font-size: 85%; padding-left: 2px; }

.ql-rich-value-pill-text { color: white; padding-right: 3px; }

.ql-rich-value-pill-text::selection, .ql-rich-value-pill-text ::selection { background: transparent !important; }

@media screen and (-ms-high-contrast: active), (forced-colors: active) {
  .preview-span::after { color: highlight; }
  .ql-background { color: highlighttext !important; background-color: transparent !important; }
  .ql-rich-value-active-pill, .ql-rich-value-inactive-pill { outline: solid 1px; background-color: transparent !important; }
  .ql-rich-value-icon, .ql-rich-value-pill-text { background-color: transparent !important; }
}

@media screen and (-ms-high-contrast: active) and (prefers-color-scheme: dark), (forced-colors: active) and (prefers-color-scheme: dark) {
  .ql-rich-value-icon, .ql-rich-value-pill-text, .ql-rich-value-active-pill, .ql-rich-value-inactive-pill { color: white !important; outline-color: white; }
}

@media screen and (-ms-high-contrast: active) and (prefers-color-scheme: light), (forced-colors: active) and (prefers-color-scheme: light) {
  .ql-rich-value-icon, .ql-rich-value-pill-text, .ql-rich-value-active-pill, .ql-rich-value-inactive-pill { color: black !important; outline-color: black; }
}

.embedconfig-itemslist-selectable { color: rgb(0, 0, 0); text-decoration: none; white-space: nowrap; }

.embedconfig-itemslist-selected { background-color: rgb(49, 154, 255); color: rgb(255, 255, 255); }

.embedconfig-rangebox { width: 100px; }

.embedconfig-rangeclear { vertical-align: middle; }

.embedconfig-rangeclear img { border-style: none; }

.embedconfig-checkbox, .embedconfig-options-list label { vertical-align: middle; }

.embedconfig-activecell { width: 175px; }

.embedconfig-dim-box { width: 25px; }

.embedconfig-dim { display: inline-block; }

.embedconfig-embedcodecontainer textarea { overflow: hidden scroll; resize: none; }

.embedconfig-code { color: rgb(85, 85, 85); }

.embedconfig-code.active { color: rgb(0, 139, 11); text-decoration: none; }

.embedconfig-separator { color: rgb(229, 229, 229); }

.embedconfig-preview { position: absolute; top: 15px; }

.embedconfig-ltr .embedconfig-preview { left: 540px; }

.embedconfig-rtl .embedconfig-preview { right: 540px; }

.embedconfig-previewcontainer, .embedconfig-previewfooter, .embedconfig-previewheader { width: 402px; }

.embedconfig-previewheader { margin-bottom: 5px; }

.embedconfig-previewcontainer { height: 346px; overflow: hidden; position: relative; }

.embedconfig-previewcontainer-inner { position: relative; }

.embedconfig-previewcontainer iframe { zoom: 1; }

.embedconfig-previewcontent { clear: both; position: relative; }

.embedconfig-previewfooter { position: absolute; top: 351px; }

.embedconfig-ltr .embedconfig-previewfooter { left: 0px; }

.embedconfig-rtl .embedconfig-previewfooter { right: 0px; }

.msospAFrameContainer img { -webkit-user-drag: none; }

.ewa-root-ltr, .ewa-root-rtl { background-color: rgb(255, 255, 255); inset: 0px; overflow: hidden; position: absolute; }

.ewa-root-ltr.flexBoxLayout, .ewa-root-rtl.flexBoxLayout { display: flex; flex-flow: column; height: 100%; }

.ewa-root-noscript { left: 50px; position: relative; top: 215px; z-index: 1002; }

.ewa-header-flexBoxLayout { flex: 0 1 auto; position: relative; }

.ewa-clientarea { bottom: 0px; left: 0px; position: absolute; right: 0px; }

.ewa-clientarea-edit { top: 178px; }

.ewa-clientarea-read { top: 40px; }

.ewa-clientarea-flexBoxLayout { flex: 1 1 auto; position: relative; top: 0px; }

.ewa-clientarea-gridLayout { display: grid; grid-template: "contentArea taskPaneArea" 1fr "statusBarArea statusBarArea" / 1fr auto; }

.ewa-clientarea.region-composer { height: 100%; position: relative; }

.ewa-clientarea-contentArea { grid-area: contentArea; }

.ewa-clientarea-taskpane { grid-area: taskPaneArea; }

.ewa-clientarea-statusBar { grid-area: statusBarArea; }

.WACStatusBarContainer.ewa-clientarea-statusBar, .WACStatusBarContainer.region-composer { position: relative; }

.ewa-contentarea { inset: 0px; overflow: hidden; position: absolute; }

.grid-visual-refresh .ewa-contentarea { background-color: rgb(245, 245, 245); }

.ewa-root-ltr .ewa-gridarea { margin-right: 0px; }

.ewa-root-rtl .ewa-gridarea { margin-left: 0px; }

.ewa-grid-ltr, .ewa-grid-rtl { inset: 0px 0px 42px; min-width: 200px; overflow: hidden; position: absolute; background-color: rgb(255, 255, 255) !important; }

iframe.ewr-slicer-container { inset: 0px; height: 100%; position: absolute; width: 100%; }

.ewa-root-ltr div.msospAFrameContainer, .ewa-root-rtl div.msospAFrameContainer { inset: 0px; display: block; margin: 0px; overflow: hidden; padding: 0px; position: absolute; }

.ewa-root-ltr div.msospAFrameContainer.cui-exth, .ewa-root-rtl div.msospAFrameContainer.cui-exth { inset: 48px 0px 0px; height: auto; overflow: visible; width: auto; }

.ewa-root-ltr div.msospAFrameContainer.cui-exth.region-composer, .ewa-root-rtl div.msospAFrameContainer.cui-exth.region-composer { top: 0px; }

.ewa-root-ltr .AppHeaderPanel, .ewa-root-rtl .AppHeaderPanel { height: 48px; left: 0px; overflow: visible; position: absolute; top: 0px; width: 100%; }

.ewa-root-ltr .AppHeaderPanel.RaisedZIndex { z-index: 999; }

.ewa-root-ltr .AppHeaderPanel.region-composer, .ewa-root-rtl .AppHeaderPanel.region-composer { position: relative; }

.ewa-root-ltr div.msospAFrameContainer.cui-exth.FlexPaneUp { left: 0px; right: 306px; }

.ewa-root-rtl div.msospAFrameContainer.cui-exth.FlexPaneUp { left: 306px; right: 0px; }

.ewa-hidden { display: none; visibility: hidden; }

.ewr-msg-ctr { bottom: 50%; color: rgb(255, 255, 255); left: 0px; position: absolute; right: 0px; text-align: center; z-index: 1003; }

.ewa-root-ltr div.msospAFrameContainer.cui-exth.flexBoxLayout, .ewa-root-rtl div.msospAFrameContainer.cui-exth.flexBoxLayout { display: flex; flex: 1 1 auto; flex-flow: column; position: relative; top: 0px; }

.wacFlexBoxAppContainer { display: flex; flex: 1 1 auto; flex-flow: row; position: relative; }

.wacFlexTaskPaneContainer-GridEnabled { display: flex; height: 100%; width: 100%; z-index: 100; }

.wacFlexTaskPaneContainer, .wacFlexTaskPaneContainerLtr { bottom: 0px; display: flex; position: absolute; top: 0px; z-index: 100; }

.wacFlexTaskPaneContainerLtr { left: auto; right: 0px; }

.wacFlexTaskPaneContainerRtl { inset: 0px auto 0px 0px; display: flex; position: absolute; z-index: 100; }

.ewa-root-ltr .wacFlexTaskPaneContainerLtr.region-composer, .ewa-root-rtl .wacFlexTaskPaneContainerRtl.region-composer { height: 100%; position: relative; }

@media screen and (orientation: landscape) {

.ewa-ptp-ltr, .ewa-ptp-rtl { background-color: initial; bottom: 0px; color: rgb(68, 68, 68); min-height: 160px; position: absolute; right: 0px; top: 0px; }

.ewa-ptp-border-ltr { border-left: 1px solid rgb(217, 217, 217); }

.ewa-ptp-border-rtl { border-right: 1px solid rgb(217, 217, 217); }

.ewa-ptp-title { background-color: initial; color: rgb(33, 115, 70); cursor: default; padding: 0px 8px; }


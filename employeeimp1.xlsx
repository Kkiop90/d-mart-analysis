.will-change { will-change: opacity, transform; contain: strict; }

@keyframes expandFromBottomRight { 
  0% { transform: scale(0); }
  40% { transform: scale(1); }
  100% { transform: scale(1); }
}

@keyframes expandFromBottomRightAndFade { 
  0% { opacity: 0; transform: scale(0); }
  6.25% { opacity: 1; }
  31.25% { opacity: 1; }
  40% { transform: scale(1); }
  50% { opacity: 0; transform: scale(1); }
  100% { opacity: 0; transform: scale(1); }
}

@keyframes expandFromBottomRight2 { 
  0% { opacity: 0; transform: scale(0); }
  6.25% { opacity: 1; transform: scale(0); }
  31.25% { opacity: 1; }
  40% { opacity: 1; transform: scale(1); }
  100% { opacity: 1; transform: scale(1); }
}

@keyframes expandFromLeft { 
  0% { transform: scaleX(0); }
  10% { transform: scaleX(0); }
  36.25% { transform: scaleX(1); }
  40% { transform: scaleX(1); }
  100% { transform: scaleX(1); }
}

@keyframes expandFromTopLeft { 
  0% { transform: scale(0); }
  15.25% { transform: scale(0); }
  40% { transform: scale(1); }
  100% { transform: scale(1); }
}

@keyframes fade-in { 
  0% { opacity: 0; }
  23.3333% { opacity: 0; }
  43.3333% { opacity: 1; }
  100% { opacity: 1; }
}

@keyframes move-right { 
  0% { transform: translate(-40px, 0px); }
  23.3333% { transform: translate(-40px, 0px); animation-timing-function: cubic-bezier(0, 0, 0, 1); }
  45.6667% { transform: translate(0px, 0px); }
  100% { transform: translate(0px, 0px); }
}

